#!/bin/bash
# =============================================================================
# Script 4: Log File Analyzer
# Author: [Your Name] | Roll: [Your Roll Number]
# Course: Open Source Software (NGMC) | OSS Capstone Project
# Software Audited: Git
# Description: Reads a log file line by line, counts keyword occurrences,
#              shows matching lines, and also analyzes a Git repository log.
# Usage: ./script4_log_analyzer.sh [logfile] [keyword]
# Example: ./script4_log_analyzer.sh /var/log/syslog error
# =============================================================================

# --- Accept command-line arguments ---
# $1 = log file path from user, $2 = optional keyword (default: "error")
LOGFILE=$1
KEYWORD=${2:-"error"}     # Default keyword is 'error' if not provided by user

# --- Counter variables ---
COUNT=0        # Counts lines that match the keyword
LINE_NUM=0     # Tracks how many lines we have read total

echo "============================================================"
echo "              LOG FILE ANALYZER                            "
echo "           Software Audited: Git                           "
echo "============================================================"
echo ""

# --- Validate: ensure a log file was provided ---
if [ -z "$LOGFILE" ]; then
    echo "  No log file specified. Trying common log locations..."
    echo ""
    # Try fallback log files in order
    if [ -f "/var/log/syslog" ]; then
        LOGFILE="/var/log/syslog"
    elif [ -f "/var/log/messages" ]; then
        LOGFILE="/var/log/messages"
    elif [ -f "/var/log/auth.log" ]; then
        LOGFILE="/var/log/auth.log"
    else
        echo "  ERROR: No log file found. Please provide one as an argument."
        echo "  Usage: $0 <logfile> [keyword]"
        exit 1
    fi
    echo "  Using fallback log file: $LOGFILE"
fi

# --- Validate: check if the specified file exists ---
if [ ! -f "$LOGFILE" ]; then
    echo "  ERROR: File '$LOGFILE' not found."
    echo "  Please provide a valid path to a log file."
    exit 1
fi

echo "  Log File : $LOGFILE"
echo "  Keyword  : '$KEYWORD'"
echo ""

# --- Do-while style retry if the file is empty ---
MAX_RETRIES=3
RETRY=0

while [ ! -s "$LOGFILE" ] && [ $RETRY -lt $MAX_RETRIES ]; do
    RETRY=$((RETRY + 1))
    echo "  WARNING: '$LOGFILE' is empty. Retry $RETRY of $MAX_RETRIES..."
    sleep 1
    if [ $RETRY -eq $MAX_RETRIES ]; then
        echo "  File still empty after $MAX_RETRIES retries. Exiting."
        exit 1
    fi
done

echo "------------------------------------------------------------"
echo "  Scanning for keyword: '$KEYWORD'"
echo "------------------------------------------------------------"
echo ""

# --- While-read loop: read the log file one line at a time ---
# IFS= preserves whitespace, -r prevents backslash escaping
while IFS= read -r LINE; do
    LINE_NUM=$((LINE_NUM + 1))   # Increment line counter for each line read

    # If-then inside the loop: check if this line contains the keyword
    # grep -i = case insensitive, -q = quiet (no output, just return code)
    if echo "$LINE" | grep -iq "$KEYWORD"; then
        COUNT=$((COUNT + 1))     # Increment match counter
    fi

done < "$LOGFILE"    # Feed the file into the while loop via input redirect

# --- Print the summary results ---
echo "  Total lines scanned   : $LINE_NUM"
echo "  Lines matching '$KEYWORD' : $COUNT"
echo ""

# --- Show last 5 matching lines using tail + grep pipeline ---
if [ $COUNT -gt 0 ]; then
    echo "------------------------------------------------------------"
    echo "  LAST 5 MATCHING LINES:"
    echo "------------------------------------------------------------"
    echo ""
    grep -i "$KEYWORD" "$LOGFILE" | tail -5 | while IFS= read -r MATCH; do
        echo "  >> $MATCH"
    done
    echo ""
else
    echo "  No matches found for '$KEYWORD' in the log file."
    echo ""
fi

# --- Git repository log analysis (bonus section relevant to Git audit) ---
echo "------------------------------------------------------------"
echo "  GIT REPOSITORY LOG ANALYSIS                             "
echo "------------------------------------------------------------"
echo ""

# Check if current directory (or home) is inside a git repo
if git -C "$HOME" rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    REPO_DIR="$HOME"
elif git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    REPO_DIR="."
else
    REPO_DIR=""
fi

if [ -n "$REPO_DIR" ]; then
    echo "  Git repository found. Analyzing commit log..."
    echo ""
    COMMIT_COUNT=$(git -C "$REPO_DIR" rev-list --count HEAD 2>/dev/null || echo "0")
    BRANCH=$(git -C "$REPO_DIR" branch --show-current 2>/dev/null || echo "unknown")
    echo "  Current branch  : $BRANCH"
    echo "  Total commits   : $COMMIT_COUNT"
    echo ""
    echo "  Last 3 commits:"
    git -C "$REPO_DIR" log --oneline -3 2>/dev/null | while IFS= read -r COMMIT; do
        echo "  >> $COMMIT"
    done
else
    echo "  No git repository found in current or home directory."
    echo "  To create one: git init my-project"
    echo ""
    echo "  Showing git system info instead:"
    echo "  Git version : $(git --version 2>/dev/null || echo 'not installed')"
fi

echo ""
echo "  Keyword '$KEYWORD' found $COUNT times in $LOGFILE"
echo ""
echo "============================================================"
echo "  End of Log File Analyzer"
echo "============================================================"
